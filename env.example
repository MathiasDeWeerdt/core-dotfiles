# Core Dotfiles — Environment Configuration
# Copy this to `env` and customize:
#   cp env.example env
#   vim env
# Then run: ./install.sh
#
# If no `env` file exists, these defaults are used.

# ── Identity ─────────────────────────────────────────────────────────
TARGET_USER="mathias"
DESIRED_HOSTNAME="bytebadger"

# ── Paths ────────────────────────────────────────────────────────────
DOTFILES_DIR="$HOME/Documents/core-dotfiles"

# ── Git identity (used when generating gitconfig) ────────────────────
# These are optional — git will prompt if unset.
# GIT_USER_NAME="Your Name"
# GIT_USER_EMAIL="you@example.com"

# ── SSH ──────────────────────────────────────────────────────────────
# Key type: ed25519, rsa, ecdsa
SSH_KEY_TYPE="ed25519"

# ── Features (set to "false" to skip) ────────────────────────────────
# INSTALL_BURPSUITE="true"
# INSTALL_FLAMESHOT="true"
